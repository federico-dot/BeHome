<odoo>
    <record id="gestione_auto_modello_action" model="ir.actions.act_window">
        <field name="name">Modello</field>
        <field name="res_model">gestione_auto.modello</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="gestione_auto_modello_root" name="Modello" action="gestione_auto_modello_action" parent="gestione_auto_submenu" sequence="7"></menuitem>

    <record id="gestione_auto_modello_list" model="ir.ui.view">
        <field name="name">Modello</field>
        <field name="model">gestione_auto.modello</field>
        <field name="arch" type="xml">
            <list string="List">
                <field name="name"></field>
                <field name="active"></field>
                <field name="category"></field>
                <field name="price"></field>
                <field name="quantity"></field>
                <field name="descrizione"></field>
            </list>
        </field>
    </record>
 
    <record id="gestione_auto_modello_form" model="ir.ui.view">
        <field name="name">Modello</field>
        <field name="model">gestione_auto.modello</field>
        <field name="arch" type="xml">
            <form string="Form">
                <sheet>
                    <group>
                        <group>
                            <field name="name"></field>
                            <field name="price"></field>
                            <field name="category"></field>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"></field>
                            <field name="quantity"></field>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione">
                            <field name="descrizione"></field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="gestione_auto_modello_search" model="ir.ui.view">
        <field name="name">Modello</field>
        <field name="model">gestione_auto.modello</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"></field>
                <field name="active"></field>
                <field name="category"></field>
                <field name="price"></field>
                <field name="quantity"></field>
                <field name="descrizione"></field>
            </search>
        </field>
    </record>
</odoo>