<odoo>
    <record id="gestione_auto_marca_action" model="ir.actions.act_window">
        <field name="name">Marca</field>
        <field name="res_model">gestione_auto.marca</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="gestione_auto_marca_root" name="Marca" action="gestione_auto_marca_action" parent="gestione_auto_submenu" sequence="6" />

    <record id="gestione_auto_marca_view_list" model="ir.ui.view">
        <field name="name">Marca</field>
        <field name="model">gestione_auto.marca</field>
        <field name="arch" type="xml">
            <list string="Lista">
                <field name="name"></field>
                <field name="paese_origine"></field>
                <field name="anno_fondazione"></field>
                <field name="logo"></field>
                <field name="descrizione"></field>
            </list>
        </field>
    </record>

    <record id="gestione_auto_marca_form" model="ir.ui.view">
        <field name="name">Marca</field>
        <field name="model">gestione_auto.marca</field>
        <field name="arch" type="xml">
            <form string="Form">
                <sheet>
                    <group>
                        <group>
                            <field name="name"></field>
                            <field name="paese_origine"></field>
                        </group>
                        <group>
                            <field name="anno_fondazione"></field>
                            <field name="logo"></field>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione">
                            <field name="descrizione"></field>
                        </page>
                    </notebook>
                </sheet>            
            </form>
        </field>    
    </record>

    <record id="gestione_auto_marca_search" model="ir.ui.view">
        <field name="name">Marca</field>
        <field name="model">gestione_auto.marca</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name"></field>
                <field name="paese_origine"></field>
                <field name="anno_fondazione"></field>
                <field name="logo"></field>
                <field name="descrizione"></field>
            </search>
        </field>
    </record>
</odoo>