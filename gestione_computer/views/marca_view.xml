<odoo>
    <record id="gestione_marca_action" model="ir.actions.act_window">
        <field name="name">Gestione Marca</field>
        <field name="res_model">marca</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="gestione_marca_root" name="marca" action="gestione_computer.gestione_marca_action" parent="gestione_computer_submenu" sequence="10">
    </menuitem>

    <record id="gestione_computer_marca_view_list" model="ir.ui.view">
        <field name="name">gestione_computer.marca.list</field>
        <field name="model">marca</field>
        <field name="arch" type="xml">
            <list string="Lista">
                <field name="name"></field>
                <field name="descrizione"></field>
            </list>
        </field>
    </record>

    <record id="gestione_computer_marca_view_form" model="ir.ui.view">
        <field name="name">gestione_computer.marca.form</field>
        <field name="model">marca</field>
        <field name="arch" type="xml">
            <form string="Form Marca">
                <sheet>
                    <group>
                        <field name="name"></field>
                        <field name="descrizione"></field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="gestione_computer_marca_view_search" model="ir.ui.view">
        <field name="name">gestione_computer.marca.search</field>
        <field name="model">marca</field>
        <field name="arch" type="xml">
            <search string="searchMarca">
                <field name="name"></field>
                <field name="descrizione"></field>

                <filter string="per nome" name="filter_name_empty" domain="[('name','!=',False)]"></filter>
                <filter string="descrizione" name="filter_descrizione_empty" domain="[('descrizione','!=',False)]"></filter>
            </search>
        </field>
    </record>

</odoo>